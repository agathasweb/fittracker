# IP da máquina host na LAN (para o celular conectar via Expo Go)
# Descobrir com: hostname -I | awk '{print $1}'
LAN_IP=192.168.1.100

# JWT secret (gerar com `openssl rand -hex 32`)
JWT_SECRET=

# IA para sugestões de cardápio (opcional — DeepSeek tb funciona)
OPENAI_API_KEY=
