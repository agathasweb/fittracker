{
  "expo": {
    "name": "FitTracker",
    "slug": "fittracker",
    "version": "0.3.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "fittracker",
    "icon": "./assets/icon.png",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b6bf1812-5f86-469c-8206-275a83ba6008",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "NEVER"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agathasweb.fittracker"
    },
    "android": {
      "package": "com.agathasweb.fittracker",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-updates",
      [
        "expo-image-picker",
        {
          "photosPermission": "O FitTracker precisa acessar suas fotos pra você definir uma foto de perfil.",
          "cameraPermission": "O FitTracker precisa acessar a câmera pra tirar sua foto de perfil."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#A3E635"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b6bf1812-5f86-469c-8206-275a83ba6008"
      }
    },
    "owner": "agweb"
  }
}
